# Store only source video files in Git LFS.
# Generated DASH outputs (.m4s/.mpd/.m3u8) are excluded via .gitignore.
media/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
media/**/*.mkv filter=lfs diff=lfs merge=lfs -text
media/**/*.webm filter=lfs diff=lfs merge=lfs -text
media-2/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
media-2/**/*.mkv filter=lfs diff=lfs merge=lfs -text
media-2/**/*.webm filter=lfs diff=lfs merge=lfs -text
