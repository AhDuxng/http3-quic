{
    servers {
        protocols h1 h2 h3
    }
}

# FILL: Dat SITE_ADDRESS trong file .env o root project:
# 1) Co domain: SITE_ADDRESS=your-domain.com (Caddy tu cap TLS Let's Encrypt)
# 2) Chi co IP: SITE_ADDRESS=:80 (chay HTTP, khong co cert public cho IP)
{$SITE_ADDRESS} {
    encode zstd gzip

    # Co the bo sung header bao mat tai day neu can.

    @preflight method OPTIONS
    handle @preflight {
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization"
        respond "" 204
    }

    handle /media/* {
        root * /srv
        file_server
    }

    handle /media-2/* {
        root * /srv
        file_server
    }

    handle /api/* {
        reverse_proxy backend:3000
    }

    handle {
        reverse_proxy frontend:80
    }
}