# Cau hinh global Caddy
{
    # Bat tat ca giao thuc: HTTP/1.1, HTTP/2, HTTP/3 (QUIC)
    servers {
        protocols h1 h2 h3
    }

    # TAT auto-HTTPS: Caddy se KHONG tu dong xin cert tu Let's Encrypt
    # Can thiet khi chi co IP (Let's Encrypt khong cap cert cho IP)
    # Viec cau hinh TLS se duoc lam thu cong bang `tls internal` ben duoi
    auto_https off

    # Tat OCSP stapling vi dung self-signed cert (khong co OCSP server)
    ocsp_stapling off
}

# Lang nghe HTTPS tren port 443 (ca TCP va UDP cho HTTP/3)
# Dung :443 thay vi IP cu the de Caddy bind dung
:443 {
    # Dung self-signed cert noi bo (internal CA cua Caddy)
    # Browser se canh bao lan dau, bam "Proceed anyway" la xong
    # HTTP/3 (QUIC) se hoat dong sau khi browser chap nhan cert
    tls internal

    # Nen response de giam bandwidth
    encode zstd gzip

    # Xu ly CORS preflight OPTIONS request
    @preflight method OPTIONS
    handle @preflight {
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization"
        respond "" 204
    }

    # Serve file video/media tinh (video chunks .m4s, manifest .mpd)
    handle /media/* {
        root * /srv
        file_server
    }

    # Serve file video MP4 chia theo bitrate
    handle /media-2/* {
        root * /srv
        file_server
    }

    # Proxy API request den backend Node.js
    handle /api/* {
        reverse_proxy backend:3000
    }

    # Serve frontend React SPA (fallback ve index.html)
    handle {
        reverse_proxy frontend:80
    }
}

# Redirect HTTP (port 80) -> HTTPS (port 443)
:80 {
    redir https://{host}{uri} permanent
}