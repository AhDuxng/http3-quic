# ===============================
# Deploy env for docker-compose.yml
# Copy file nay thanh .env roi sua gia tri ben duoi
# ===============================

# Khong co domain -> dung HTTP voi IP server
# Giu gia tri :80 de Caddy listen cong 80
SITE_ADDRESS=:80

# FILL: thay YOUR_SERVER_IP bang IP that cua server
# Vi du: CORS_ORIGIN=http://203.0.113.10
# Co the de * neu test nhanh, nhung nen dat cu the de an toan hon
CORS_ORIGIN=http://YOUR_SERVER_IP
