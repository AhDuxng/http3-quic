# ===============================
# Env variables cho docker-compose.yml
# Copy file nay thanh .env roi chinh sua gia tri
# ===============================

# SITE_ADDRESS: dia chi Caddy lang nghe
#
# Chi co IP (khong co domain):
#   SITE_ADDRESS=203.0.113.10       -> Caddy tao self-signed cert cho IP nay
#   Browser se canh bao, bam "Proceed" -> HTTP/3 hoat dong
#
# Co domain that (khuyen nghi):
#   SITE_ADDRESS=your-domain.com   -> Caddy tu dong cap Let's Encrypt, HTTP/3 chay ngay khong can canh bao
#   Nho xoa dong `tls internal` trong caddy_config/Caddyfile khi dung domain that
#
# KHONG dung :80 hoac :443 don thuan - phai co IP/domain cu the de cert dung
SITE_ADDRESS=YOUR_SERVER_IP

# CORS_ORIGIN: phai match voi SITE_ADDRESS
# Chi co IP: CORS_ORIGIN=https://YOUR_SERVER_IP
# Co domain: CORS_ORIGIN=https://your-domain.com
CORS_ORIGIN=https://YOUR_SERVER_IP
